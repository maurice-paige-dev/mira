FROM node:22-alpine AS builder
ARG VITE_API_URL=/chat
ENV VITE_API_URL=${VITE_API_URL}
WORKDIR /app
COPY frontend/chatbot/package.json frontend/chatbot/package-lock.json ./
RUN npm ci
COPY frontend/chatbot/ .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=builder /app/dist/ /usr/share/nginx/html/chatbot/
COPY frontend/catalog/ /usr/share/nginx/html/catalog/
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
